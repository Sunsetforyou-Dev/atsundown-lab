# Google Gemini API key for the Node.js chat assistant.
GOOGLE_API_KEY=your_google_api_key_here

# Optional Node.js app settings.
PORT=3000
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Google Sheets settings for saving ready-made FiveM script orders.
GOOGLE_SHEETS_ID=your_google_sheet_id_here

# Use one of these credential options:
# Option 1: local service account JSON file path.
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json

# Option 2: raw service account JSON string, useful for deployment secrets.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Telegram bot settings for admin order notifications.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
